{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)"
  ],
  "timezone": "America/Chicago",
  "schedule": [
    "before 6am"
  ],
  "labels": [
    "dependencies"
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "non-major dependencies"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "postUpdateOptions": [
        "gomodTidy"
      ]
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "groupName": "container images"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/security\\.yml$/"
      ],
      "matchStrings": [
        "GOVULNCHECK_VERSION: (?<currentValue>v[0-9.]+)"
      ],
      "depNameTemplate": "golang.org/x/vuln",
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/release\\.yml$/"
      ],
      "matchStrings": [
        "GORELEASER_VERSION: (?<currentValue>v[0-9.]+)"
      ],
      "depNameTemplate": "github.com/goreleaser/goreleaser/v2",
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/release\\.yml$/"
      ],
      "matchStrings": [
        "SYFT_VERSION: (?<currentValue>v[0-9.]+)"
      ],
      "depNameTemplate": "anchore/syft",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/(security|release)\\.yml$/"
      ],
      "matchStrings": [
        "TRIVY_VERSION: (?<currentValue>v[0-9.]+)"
      ],
      "depNameTemplate": "aquasecurity/trivy",
      "datasourceTemplate": "github-releases"
    }
  ]
}

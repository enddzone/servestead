# syntax=docker/dockerfile:1.25

ARG GO_VERSION=1.26.4

FROM golang:${GO_VERSION}-bookworm AS build
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY backend ./backend
COPY frontend ./frontend
RUN go tool templ generate
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /out/servestead ./backend

FROM cgr.dev/chainguard/git:latest-glibc
COPY --from=build /out/servestead /servestead

USER 65532:65532
ENTRYPOINT ["/servestead"]

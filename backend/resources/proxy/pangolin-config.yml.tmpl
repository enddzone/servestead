gerbil:
  start_port: 51820
  base_endpoint: {{ yamlSingleQuote .DashboardHost }}
app:
  dashboard_url: {{ yamlSingleQuote .DashboardURL }}
  log_level: info
  telemetry:
    anonymous_usage: true
domains:
  domain1:
    base_domain: {{ yamlSingleQuote .BaseDomain }}
server:
  secret: {{ yamlSingleQuote .ServerSecret }}
  cors:
    origins:
      - {{ yamlSingleQuote .DashboardURL }}
    methods:
      - GET
      - POST
      - PUT
      - DELETE
      - PATCH
    allowed_headers:
      - X-CSRF-Token
      - Content-Type
    credentials: false
flags:
  require_email_verification: false
  disable_signup_without_invite: true
  disable_user_create_org: false
  allow_raw_resources: true

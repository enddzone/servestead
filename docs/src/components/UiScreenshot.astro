---
import { Image } from 'astro:assets';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption: string;
  eager?: boolean;
}

const { src, alt, caption, eager = false } = Astro.props;
---

<figure class="ui-screenshot">
  <div class="ui-screenshot__frame">
    <Image
      src={src}
      alt={alt}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      widths={[640, 960, 1280]}
      sizes="(max-width: 50rem) calc(100vw - 2rem), min(100vw - 24rem, 52rem)"
    />
  </div>
  <figcaption>{caption}</figcaption>
</figure>

<style>
  .ui-screenshot {
    min-width: 0;
    margin: 2rem 0;
    overflow: hidden;
    border: 1px solid var(--sv-border, var(--sl-color-gray-5));
    border-radius: 0.75rem;
    background: var(--sv-panel, var(--sl-color-bg-nav));
    box-shadow: 0 20px 80px rgb(0 0 0 / 18%), inset 0 1px 0 rgb(255 255 255 / 4%);
  }

  .ui-screenshot__frame {
    min-width: 0;
    padding: clamp(0.35rem, 1vw, 0.65rem);
    background:
      radial-gradient(circle at top left, rgb(203 166 247 / 14%), transparent 36%),
      var(--sv-crust, var(--sl-color-bg));
  }

  img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--sv-border, var(--sl-color-gray-5));
    border-radius: 0.5rem;
  }

  figcaption {
    margin: 0;
    padding: 0.8rem 1rem 0.9rem;
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
    line-height: 1.5;
  }
</style>

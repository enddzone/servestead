services:
  pangolin:
    image: {{ .PangolinImage }}
    container_name: pangolin
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      PANGOLIN_SETUP_TOKEN: {{ yamlDoubleQuote .SetupToken }}
    volumes:
      - ./config:/app/config
    ports:
      - "127.0.0.1:3000:3000"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3001/api/v1/"]
      interval: "10s"
      timeout: "10s"
      retries: 15

  gerbil:
    image: {{ .GerbilImage }}
    container_name: gerbil
    restart: unless-stopped
    depends_on:
      pangolin:
        condition: service_healthy
    command:
      - --reachableAt=http://gerbil:3004
      - --generateAndSaveKeyTo=/var/config/key
      - --remoteConfig=http://pangolin:3001/api/v1/
    volumes:
      - ./config:/var/config
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    ports:
      - "51820:51820/udp"
      - "21820:21820/udp"
      - "443:443"
      - "80:80"

  traefik:
    image: {{ .TraefikImage }}
    container_name: traefik
    restart: unless-stopped
    network_mode: service:gerbil
    depends_on:
      pangolin:
        condition: service_healthy
    command:
      - --configFile=/etc/traefik/traefik_config.yml
    volumes:
      - ./config/traefik:/etc/traefik:ro
      - ./config/letsencrypt:/letsencrypt
      - ./config/traefik/logs:/var/log/traefik

  socket-proxy:
    image: {{ .SocketProxyImage }}
    container_name: aegis-socket-proxy
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    environment:
      CONTAINERS: "1"
      EVENTS: "1"
      INFO: "1"
      NETWORKS: "1"
      PING: "1"
      VERSION: "1"
      POST: "0"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - {{ .AegisPublicNetwork }}

  newt:
    image: {{ .NewtImage }}
    container_name: aegis-newt
    restart: unless-stopped
    depends_on:
      - socket-proxy
    environment:
      PANGOLIN_ENDPOINT: {{ yamlDoubleQuote .PangolinEndpoint }}
      NEWT_ID: {{ yamlDoubleQuote .NewtID }}
      NEWT_SECRET: {{ yamlDoubleQuote .NewtSecret }}
      DOCKER_SOCKET: "tcp://socket-proxy:2375"
      DOCKER_ENFORCE_NETWORK_VALIDATION: "true"
    networks:
      - {{ .AegisPublicNetwork }}

networks:
  default:
    driver: bridge
    name: pangolin
    ipam:
      config:
        - subnet: {{ .ProxyDockerSubnet }}
  {{ .AegisPublicNetwork }}:
    external: true

# Copy this file to .env and replace every value with your AirVPN values.
# Do not commit the real .env file.

AIRVPN_WIREGUARD_PRIVATE_KEY=replace-with-airvpn-wireguard-private-key
AIRVPN_WIREGUARD_PRESHARED_KEY=replace-with-airvpn-wireguard-preshared-key
AIRVPN_WIREGUARD_ADDRESSES=10.0.0.2/32
AIRVPN_SERVER_COUNTRIES=United States
AIRVPN_FORWARDED_PORT=12345
